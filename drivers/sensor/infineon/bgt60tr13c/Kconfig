menuconfig BGT60TR13C
	bool "Infineon XENSIV BGT60TR13C 60 GHz radar sensor"
	default y
	depends on DT_HAS_INFINEON_BGT60TR13C_ENABLED
	select SPI
	select GPIO
	help
	  Enable driver for the Infineon XENSIV BGT60TR13C 60 GHz FMCW
	  radar sensor with integrated antennas.

if BGT60TR13C

choice BGT60TR13C_TRIGGER_MODE
	prompt "Trigger mode"
	default BGT60TR13C_TRIGGER_GLOBAL_THREAD
	help
	  Specify the type of triggering to be used by the driver.

config BGT60TR13C_TRIGGER_NONE
	bool "No trigger"

config BGT60TR13C_TRIGGER_GLOBAL_THREAD
	bool "Use global thread"
	depends on GPIO
	select BGT60TR13C_TRIGGER

config BGT60TR13C_TRIGGER_OWN_THREAD
	bool "Use own thread"
	depends on GPIO
	select BGT60TR13C_TRIGGER

endchoice

config BGT60TR13C_TRIGGER
	bool

config BGT60TR13C_THREAD_PRIORITY
	int "Thread priority"
	depends on BGT60TR13C_TRIGGER_OWN_THREAD
	default 10
	help
	  Priority of thread used by the driver to handle interrupts.

config BGT60TR13C_THREAD_STACK_SIZE
	int "Thread stack size"
	depends on BGT60TR13C_TRIGGER_OWN_THREAD
	default 1024
	help
	  Stack size of thread used by the driver to handle interrupts.

endif # BGT60TR13C
